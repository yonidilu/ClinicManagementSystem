<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
      fx:controller="com.clinic.controller.ChoiceController" style="-fx-background-color: #2c3e50;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <VBox spacing="5" alignment="CENTER">
        <Label text="WELCOME TO MEDICAL ENTERPRISE HUB" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
        <Label text="Please select your authorized department role to claim a secure session" style="-fx-font-size: 14px; -fx-text-fill: #bdc3c7;"/>
    </VBox>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="doctorPortalBtn" text="Doctor Clinical Hub" onAction="#handleRoleSelection"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 20; -fx-cursor: hand;"/>

        <Button fx:id="receptionPortalBtn" text="Reception Registry &amp; Billing" onAction="#handleRoleSelection"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 20; -fx-cursor: hand;"/>

        <Button fx:id="laboratoryPortalBtn" text="Pathology Laboratory System" onAction="#handleRoleSelection"
                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 20; -fx-cursor: hand;"/>

        <Button fx:id="hrPortalBtn" text="Human Resources Admin" onAction="#handleRoleSelection"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 20; -fx-cursor: hand;"/>
    </HBox>
</VBox>