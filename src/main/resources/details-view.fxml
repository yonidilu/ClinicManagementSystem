<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" prefHeight="300" prefWidth="400"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinic.controller.DetailsController" style="-fx-padding: 20;">

    <Label fx:id="detailsLabel" text="Patient Detailed Record" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Separator/>

    <GridPane vgap="10" hgap="10" alignment="CENTER">
        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="nameLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Ailment:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <Label fx:id="ailmentLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Fayda ID:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <Label fx:id="faydaLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <Button text="Close" onAction="#onCloseClick" prefWidth="100"/>

</VBox>