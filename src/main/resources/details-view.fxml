<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.clinic.controller.DetailsController"
      style="-fx-padding: 30; -fx-background-color: #ecf0f1;">
    <Label text="Patient Medical Record" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Separator/>
    <Label fx:id="detailsLabel" style="-fx-font-size: 14px; -fx-font-family: 'Monospaced';" wrapText="true"/>
    <Button text="Close" onAction="#onCloseClick" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
</VBox>


