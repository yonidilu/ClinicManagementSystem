<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" prefHeight="300" prefWidth="400"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinic.controller.DetailsController" style="-fx-padding: 20;">

    <Label fx:id="detailsLabel" text="Patient Detailed Record" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Separator/>

    <GridPane vgap="10" hgap="10" alignment="CENTER">
        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="fullNameLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
        <Label fx:id="dobLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
        <Label fx:id="idLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Doctor:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
        <Label fx:id="doctorLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Diagnosis:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
        <Label fx:id="diagnosisLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Treatment:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;"/>
        <Label fx:id="treatmentLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Appointment:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold;"/>
        <Label fx:id="appointmentLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="Payment:" GridPane.columnIndex="0" GridPane.rowIndex="7" style="-fx-font-weight: bold;"/>
        <Label fx:id="paymentLabel" text="Loading..." GridPane.columnIndex="1" GridPane.rowIndex="7"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="View Lab Results" onAction="#onOpenLabResults"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Close" onAction="#onClose" />
    </HBox>

</VBox>