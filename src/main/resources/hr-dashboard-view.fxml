<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinic.controller.HRDashboardController"
      alignment="CENTER" spacing="30.0" prefHeight="400.0" prefWidth="600.0"
      style="-fx-background-color: #2c3e50;">

    <Label text="HR ADMINISTRATION PORTAL" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <Button text="Go to Hiring/Registration" onAction="#handleOpenHiringForm"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20;"/>

    <Button text="Logout" onAction="#handleLogout"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
</VBox>