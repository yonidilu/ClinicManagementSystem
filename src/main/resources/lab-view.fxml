<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinic.controller.LabController" style="-fx-padding: 20;">

    <Label text="Patient Lab History" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
    <Label fx:id="patientInfoLabel" text="Patient: [Name] (ID: [ID])" />

    <TableView fx:id="labTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="testColumn" text="Test Name" prefWidth="150"/>
            <TableColumn fx:id="resultColumn" text="Result" prefWidth="150"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <ComboBox fx:id="testComboBox" promptText="Select Test" prefWidth="150"/>
        <TextField fx:id="resultInput" promptText="Result (e.g. 110 mg/dL)"/>

        <Button text="Add Result" onAction="#handleAddResult"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>

        <Button text="Remove" onAction="#handleDeleteResult"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>

        <Button text="Print PDF" onAction="#handlePrintPDF"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
    </HBox>
</VBox>