<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.clinic.controller.MainController"
      spacing="15" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Clinic Patient Registry" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox spacing="8" alignment="CENTER" maxWidth="400" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
        <Label text="New Patient Registration" style="-fx-font-weight: bold;"/>
        <TextField fx:id="patientNameField" promptText="Patient Name"/>
        <TextField fx:id="ailmentField" promptText="Ailment/Issue"/>
        <TextField fx:id="genderField" promptText="Gender"/>
        <TextField fx:id="contactField" promptText="Contact No"/>
        <TextField fx:id="statusField" promptText="Status (e.g. Waiting)"/>
        <TextField fx:id="faydaField" promptText="Fayda ID"/>
        <Button text="Add Patient" onAction="#onRegisterButtonClick"
                maxWidth="Infinity" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>

    <Separator />

    <TextField fx:id="searchField" promptText="Search patients by name or ID..." maxWidth="800"/>

    <TableView fx:id="patientTable" prefHeight="300" prefWidth="800">
        <columns>
            <TableColumn fx:id="nameColumn" text="Patient Name" prefWidth="120" />
            <TableColumn fx:id="ailmentColumn" text="Ailment" prefWidth="120" />
            <TableColumn fx:id="genderColumn" text="Gender" prefWidth="80" />
            <TableColumn fx:id="contactColumn" text="Contact" prefWidth="120" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
            <TableColumn fx:id="faydaColumn" text="Fayda ID" prefWidth="100" />
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Remove Selected" onAction="#onDeleteButtonClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="View Details" onAction="#onShowDetails" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
    </HBox>

    <Label fx:id="countLabel" text="Total Patients: 0" style="-fx-font-italic: true;"/>
</VBox>