<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinic.controller.MainController" style="-fx-background-color: white;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Clinic Patient Registry" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="patientNameField" promptText="Patient Name" prefWidth="150"/>
        <TextField fx:id="ailmentField" promptText="Ailment/Issue" prefWidth="150"/>
        <TextField fx:id="faydaField" promptText="Fayda ID" prefWidth="150"/>
        <Button text="Add Patient" onAction="#onRegisterButtonClick" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TableView fx:id="patientTable" prefHeight="300" prefWidth="550">
        <columns>
            <TableColumn text="Name" prefWidth="180">
                <cellValueFactory><PropertyValueFactory property="name" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Ailment" prefWidth="250">
                <cellValueFactory><PropertyValueFactory property="ailment" /></cellValueFactory>
            </TableColumn>
            <TableColumn text="Fayda" prefWidth="100">
                <cellValueFactory><PropertyValueFactory property="fayda" /></cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox fx:id="adminControls" spacing="15" alignment="CENTER">
        <Button text="Remove Selected" onAction="#onDeleteButtonClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="View Details" onAction="#onShowDetails" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
    </HBox>

    <Label fx:id="countLabel" text="Total Patients: 0" style="-fx-font-italic: true;"/>
</VBox>