<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox fx:controller="com.clinic.controller.MainController"
      spacing="15" alignment="TOP_CENTER"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@style.css">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Clinic Patient Registry" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox fx:id="receptionFormSection" spacing="10" alignment="CENTER" maxWidth="950"
          style="-fx-background-color: #f8f9fa; -fx-padding: 20; -fx-border-color: #dcdde1; -fx-border-radius: 5;">

        <Label text="Patient Registration &amp; Update Management" style="-fx-font-weight: bold; -fx-font-size: 16;"/>

        <GridPane hgap="20" vgap="12" alignment="CENTER">
            <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Personal Details" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
                <TextField fx:id="nameField" promptText="Patient's Full Name"/>

                <ComboBox fx:id="genderComboBox" promptText="Select Gender" maxWidth="Infinity">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Male" />
                            <String fx:value="Female" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <DatePicker fx:id="dobDatePicker" promptText="Select Date of Birth" maxWidth="Infinity"/>

                <TextField fx:id="contactField" promptText="Contact Number"/>
            </VBox>

            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Administrative Triage" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
                <ComboBox fx:id="doctorComboBox" promptText="Select Assigned Doctor" maxWidth="Infinity"/>
                <TextField fx:id="statusField" promptText="Status (e.g., Waiting, In-Progress)"/>

                <DatePicker fx:id="apptDatePicker" promptText="Select Appointment Date" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Administrative Fees" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
                <TextField fx:id="faydaField" promptText="ID (National ID / Fayda)"/>
                <TextField fx:id="paidAmountField" promptText="Paid Amount"/>
            </VBox>
        </GridPane>

        <Button fx:id="registerButton" text="Add New Patient Record" onAction="#handleAddPatient"
                maxWidth="400" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;">
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
        </Button>
    </VBox>

    <Separator />

    <TextField fx:id="searchField" promptText="Search patient files by name or unique ID..." maxWidth="800"/>

    <TableView fx:id="patientTable" prefHeight="300" prefWidth="900">
        <columns>
            <TableColumn fx:id="faydaColumn" text="ID" prefWidth="90" />
            <TableColumn fx:id="nameColumn" text="Patient Name" prefWidth="140" />
            <TableColumn fx:id="dobColumn" text="Date of Birth" prefWidth="100" />
            <TableColumn fx:id="genderColumn" text="Gender" prefWidth="80" />
            <TableColumn fx:id="contactColumn" text="Contact" prefWidth="120" />
            <TableColumn fx:id="doctorColumn" text="Assigned Doctor" prefWidth="130" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
            <TableColumn fx:id="regDateColumn" text="Reg. Date" prefWidth="110" />
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="removeSelectedButton" text="Remove Selected Record" onAction="#handleRemoveSelected"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button fx:id="editSelectedButton" text="Edit Credentials" onAction="#onEditButtonClick"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="View File Details" onAction="#onShowDetails"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="billingButton" text="Open Financial Ledger (Billing)" onAction="#onBillingButtonClick"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="viewHistoryBtn" text="Open Clinical Medical History" onAction="#handleViewHistory"
                style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Sign Out" onAction="#handleLogout"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" />
    </HBox>

    <Label fx:id="countLabel" text="Total Active Records: 0" style="-fx-font-italic: true;"/>
</VBox>